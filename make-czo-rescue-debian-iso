#         -no-emul-boot
#         -isohybrid-gpt-basdat
#     -o ../$NAME.iso .

}

(

run_once make_01_prepare
run_once make_02_chroot
run_once make_03_copyfiles
run_once make_04_squashfs
run_once make_05_bootloader
run_once make_06_iso

) 2>&1 | tee -a $LOG


exit
