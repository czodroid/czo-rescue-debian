make_04_squashfs() {

echo "-> Squashfs ==============================================="

rm -f $LIVE_BOOT/staging/live/filesystem.squashfs

## fatser
mksquashfs $LIVE_BOOT/chroot $LIVE_BOOT/staging/live/filesystem.squashfs -e boot
